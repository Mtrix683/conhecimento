@model List<AvaliacaoTecnica.Models.Produto>

<h2 class="mb-4">Lista de Produtos</h2>

<form method="get" class="mb-3">
    <input type="text" name="busca" placeholder="Buscar produto" class="form-control" />
    <button type="submit" class="btn btn-secondary mt-2">Buscar</button>
</form>

<p>
    <a asp-action="Create" class="btn btn-primary">Criar Novo Produto</a>
</p>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Nome</th>
            <th>Descrição</th>
            <th>Preço</th>
            <th>Categoria</th>
            <th>Ações</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Nome</td>
                <td>@item.Descricao</td>
                <td>@item.Preco.ToString("C")</td>
                <td>@item.Categoria</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>