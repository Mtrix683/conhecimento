@model List<AvaliacaoTecnica.Models.Produto>

<h2 class="mb-4">Lista de Produtos</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Criar Novo Produto</a>
</p>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Nome</th>
            <th>Descrição</th>
            <th>Preço</th>
            <th>Categoria</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Nome</td>
                    <td>@item.Descricao</td>
                    <td>@item.Preco</td>
                    <td>@item.Categoria</td>
                </tr>
            }
        }
    </tbody>
</table>